__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.env

# PDF binaries are large — ignore them; but commit URL sidecars (tiny text files)
data/cache/pdf/*.pdf
data/cache/pdf/*.pdf.part

# Guidance PDF binaries — ignore; the parsed chunk JSON snapshot IS committed.
data/cache/guidance_pdf/*.pdf

# Chunk JSON files — commit pre-indexed devices so Vercel can serve them
# without needing a writable filesystem.
data/cache/labs/
data/cache/labs/

# openFDA JSON cache IS committed (small; used for deterministic test replay)
# Exception: do not commit snapshot files that may be large
data/cache/snapshot_*.json

.DS_Store
.vercel
.claude/
